# ============================================================
# AgentHub API — required environment variables
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Core ---
# Database. Local dev defaults to SQLite (zero setup).
# Supabase example: postgresql+asyncpg://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite+aiosqlite:///./agenthub.db

# JWT signing secret. GENERATE A STRONG RANDOM VALUE in prod:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# Comma-separated allowed CORS origins (the frontend URL).
CORS_ORIGINS=http://localhost:3000

# --- LLM ---
# Provider implementation to use (anthropic | openai | gemini | mock).
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-haiku-4-5

# Direct Anthropic access:
ANTHROPIC_API_KEY=sk-ant-...

# OR an Anthropic-compatible gateway (e.g. z.ai). If set, Bearer auth is used.
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# --- Guardrails ---
# Per-user LLM requests allowed per minute (0 = unlimited).
RATE_LIMIT_PER_MIN=20

# --- Pipeline ---
# Path (relative to repo root) to the agents source CSV.
AGENTS_CSV_PATH=data/agents_sample.csv
